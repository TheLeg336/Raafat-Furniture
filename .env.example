VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated list of emails allowed to access the admin panel
VITE_ALLOWED_ADMIN_EMAILS=your.email@gmail.com,another.admin@gmail.com

# Cloudinary — ALL file hosting (product images, GLB/3D models, scan frames).
# We do not use Firebase Storage. Public (safe in the client): cloud name + UNSIGNED upload preset.
# For GLB uploads, the unsigned preset must allow Raw (or Auto) resource types.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
# Server-only secrets (used by the /api/cloudinary/delete endpoint). DO NOT use the VITE_ prefix.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini auto-translation — SERVER-ONLY key (proxied via /api/translate; never shipped to the browser).
GEMINI_API_KEY=

# ---- Store ----
# ISO currency code used across the store (e.g. USD, EGP, EUR)
VITE_STORE_CURRENCY=USD

# ---- Google Analytics 4 (consent-gated; no cookies until the user opts in) ----
VITE_GA_MEASUREMENT_ID=

# ---- Stripe ----
# Publishable key is exposed to the client; secret + webhook secret stay server-only.
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Transactional email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM=Raafat Furniture <orders@yourdomain.com>
CONTACT_EMAIL=
SITE_URL=https://raafat-furniture.vercel.app
# Reply-to for order threads (plus-addressing: orders+{orderId}@yourdomain.com)
EMAIL_REPLY_TO=orders@yourdomain.com
# Optional shared secret for POST /api/email/inbound (?secret= or x-webhook-secret)
RESEND_INBOUND_SECRET=

# ---- Firebase Admin (server-side trust: secure orders + Stripe webhook writes) ----
# Either paste the service-account JSON on one line, OR set GOOGLE_APPLICATION_CREDENTIALS to its path.
FIREBASE_SERVICE_ACCOUNT=
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ---- Photogrammetry reconstruction (optional) ----
# Endpoint that turns captured scan frames into a GLB and writes the URL back to the scan doc.
# Without it, scans are captured + queued and an admin attaches the finished model manually.
VITE_PHOTOGRAMMETRY_API_URL=


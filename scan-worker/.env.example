# Firebase Admin — path to a service-account JSON file, or the JSON itself.
# Same account as the site's FIREBASE_SERVICE_ACCOUNT.
FIREBASE_SERVICE_ACCOUNT=./service-account.json

# Cloudinary (server credentials, NOT the unsigned preset) — Dashboard -> API Keys.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Photogrammetry engine: path to meshroom_batch(.exe) from Meshroom (free, CUDA).
# https://alicevision.org/#meshroom  — e.g. C:\Meshroom\meshroom_batch.exe
MESHROOM_BIN=meshroom_batch

# Optional: Blender 4.x for USDZ export (iOS AR Quick Look). Leave empty to skip.
# e.g. C:\Program Files\Blender Foundation\Blender 4.2\blender.exe
BLENDER_BIN=

# Local dashboard port (open http://localhost:8787 to see pending jobs)
PORT=8787

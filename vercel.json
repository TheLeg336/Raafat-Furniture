{
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/**"
    },
    "api/stripe-webhook.ts": {
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/api/stripe/webhook", "destination": "/api/stripe-webhook" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}

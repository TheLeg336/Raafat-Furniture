rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && (
        (request.auth.token.email == "youssefhanna336@gmail.com" && request.auth.token.email_verified == true) ||
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.token.email.lower()))
      );
    }

    // Finished 3D models — world-readable (users view & AR them), admin-writable.
    match /models/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 50 * 1024 * 1024
                   && request.resource.contentType.matches('model/.*|application/octet-stream');
    }

    // Raw scan frames — admin-only (may contain incidental surroundings).
    match /scans/{scanId}/{frame} {
      allow read: if isAdmin();
      allow write: if isAdmin()
                   && request.resource.size < 12 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
